    "next-intl": "^3.25.0",
    "next-pwa": "^5.6.0",
    "recharts": "^2.13.0",
    "openai": "^4.73.0",
    "@stripe/stripe-js": "^4.8.0",
    "stripe": "^17.4.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.5.4",
    "framer-motion": "^11.11.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.0.0",
    "wrangler": "^4.59.0",
    "typescript": "^5.6.0",
    "@types/node": "^22.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
